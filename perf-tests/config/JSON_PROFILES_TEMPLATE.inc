# This template is used for the autogenerated json content profiles of the OpenAPI import
,{
    "name" : "json_{{JCP_METHOD}}_{{JCP_URI}}",
    "attackSignaturesCheck" : true,
    "defenseAttributes" : {
        "maximumArrayLength" : {{MO_VALUE_EXPAND_OR_DEFAULT 'VAR_JSON_MAX_ARRAY_LENGTH_' {{JCP_FRIENDLY_VAR}} {{VAR_JSON_MAX_ARRAY_LENGTH}}}},
        "maximumStructureDepth" : {{MO_VALUE_EXPAND_OR_DEFAULT 'VAR_JSON_MAX_STRUCTURE_DEPTH_' {{JCP_FRIENDLY_VAR}} {{VAR_JSON_MAX_STRUCTURE_DEPTH}}}},
        "maximumTotalLengthOfJSONData" : {{MO_VALUE_EXPAND_OR_DEFAULT 'VAR_JSON_MAX_DATA_LENGTH_' {{JCP_FRIENDLY_VAR}} {{VAR_JSON_MAX_DATA_LENGTH}}}},
        "maximumValueLength" : {{MO_VALUE_EXPAND_OR_DEFAULT 'VAR_JSON_MAX_VALUE_LENGTH_' {{JCP_FRIENDLY_VAR}} {{VAR_JSON_MAX_VALUE_LENGTH}}}},
        "tolerateJSONParsingWarnings" : true
    },
    "handleJsonValuesAsParameters" : false,
    "hasValidationFiles" : true,
    "signatureOverrides" : [
        {{#ARRAY_JSON_DISABLED_SIGNATURES}}
            {{MO_COMMA_IF_NOT_FIRST}}
            {
                "enabled" : false,
                "signatureId" : {{.}}
            }
        {{/ARRAY_JSON_DISABLED_SIGNATURES}}
    ],
    "sensitiveData" : [
        {{#ARRAY_JSON_SENSITIVE_DATA}}
            {{MO_COMMA_IF_NOT_FIRST}}
            {
                "parameterName" : "{{.}}"
            }
        {{/ARRAY_JSON_SENSITIVE_DATA}}
    ]
}
